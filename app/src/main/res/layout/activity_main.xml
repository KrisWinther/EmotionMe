<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".MainActivity">
    <FrameLayout
        android:id="@+id/backgroundContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#EAF3FF"> <!-- Основной градиент -->

        <!-- Пятно 1 -->
        <View
            android:id="@+id/spot1"
            android:layout_width="300dp"
            android:layout_height="300dp"
            android:layout_gravity="top|end"
            android:background="@drawable/oval_blue_gradient" />

        <!-- Пятно 2 -->
        <View
            android:id="@+id/spot2"
            android:layout_width="300dp"
            android:layout_height="300dp"
            android:layout_gravity="center"
            android:background="@drawable/oval_orange_gradient" />

        <View
            android:id="@+id/spot3"
            android:layout_width="300dp"
            android:layout_height="300dp"
            android:layout_gravity="bottom|start"
            android:background="@drawable/oval_violet_gradient" />

        <!-- МАТовый слой (Glassmorphism) -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#60FFFFFF" /> <!-- Полупрозрачный белый -->

    </FrameLayout>

    <FrameLayout
        android:id="@+id/main_frame"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/field_frame_2"
        android:backgroundTint="@color/lavender"
        android:paddingTop="27dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/greets"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center|start"
            android:layout_marginStart="12dp"
            android:padding="10dp"
            android:text="Главная"
            android:textColor="@color/white"
            android:textSize="23sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnSettings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center|end"
            android:backgroundTint="@color/lavender"
            android:gravity="center"
            android:padding="10dp"
            android:layout_marginEnd="12dp"
            android:textColor="@color/white"
            app:drawableEndCompat="@drawable/baseline_settings_24"
            app:drawableTint="@color/white"
            android:textSize="30sp"/>
    </FrameLayout>

    <ScrollView
        android:id="@+id/scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/motivationContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/main_frame">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="25dp"
            android:paddingEnd="25dp"
            android:paddingBottom="10dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:background="@drawable/field_light"
                android:padding="10dp">

                <TextView
                    android:id="@+id/mainTV"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:text="🌟 Опиши свой момент"
                    android:textColor="@color/black"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <Spinner
                android:id="@+id/spinnerMood"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:popupBackground="@drawable/field_scroll"
                android:scrollbarSize="100dp"
                android:paddingTop="20dp"
                android:paddingBottom="20dp"
                android:layout_gravity="center"
                android:gravity="center"
                android:background="@drawable/field_scroll" />

            <Spinner
                android:id="@+id/spinnerPlace"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:popupBackground="@drawable/field_scroll"
                android:scrollbarSize="100dp"
                android:paddingTop="20dp"
                android:paddingBottom="20dp"
                android:layout_gravity="center"
                android:gravity="center"
                android:background="@drawable/field_scroll" />

            <Spinner
                android:id="@+id/spinnerWeather"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:popupBackground="@drawable/field_scroll"
                android:scrollbarSize="100dp"
                android:paddingTop="20dp"
                android:paddingBottom="20dp"
                android:layout_gravity="center"
                android:gravity="center"
                android:background="@drawable/field_scroll" />

            <EditText
                android:id="@+id/etNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="@color/black"
                android:textColorHint="@color/grey"
                android:textCursorDrawable="@drawable/cursor_color"
                android:background="@drawable/field_light"
                android:hint="Здесь можно оставить заметку"
                android:padding="25dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:backgroundTint="@color/lavender"
                android:text="💾 Сохранить"
                app:cornerRadius="15dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/black"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:text="📊 Статистика"
                app:cornerRadius="15dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNotes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/black"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:text="💭 Заметки"
                app:cornerRadius="15dp"/>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/motivationContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/field_frame_bottom"
        android:backgroundTint="@color/lavender"
        app:layout_constraintBottom_toBottomOf="parent">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="5dp"
            android:paddingStart="5dp"
            android:paddingEnd="5dp">

            <TextView
                android:id="@+id/showMotivation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:layout_marginEnd="15dp"
                android:layout_marginStart="15dp"
                android:background="@drawable/field_frame_bottom"
                android:gravity="center"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="20dp"
                android:paddingBottom="30dp"
                android:textColor="@color/black"
                android:textSize="20sp"
                android:textStyle="bold" />
        </FrameLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
